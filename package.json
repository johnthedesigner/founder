{
  "name": "ds-gen",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "backend",
    "frontend",
    "preview-sandbox",
    "cli"
  ],
  "scripts": {
    "dev": "concurrently --names 'frontend,preview' 'npm run dev --workspace=frontend' 'npm run dev --workspace=preview-sandbox'",
    "build": "npm run build --workspace=frontend && npm run build --workspace=preview-sandbox",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit -p packages/types/tsconfig.json && tsc --noEmit -p backend/tsconfig.json"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^9.15.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.15.0"
  }
}
